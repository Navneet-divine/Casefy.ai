{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "rootDir": ".",
    "outDir": "./dist",

    "lib": ["ES2023"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],

    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    "allowSyntheticDefaultImports": true
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules", "dist"]
}
